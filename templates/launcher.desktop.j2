[Desktop Entry]
Version=1.0
Type=Application
Name={{ jetbrains_ide_info[jetbrains_ide].name }}
Icon={{ ide_unpack_dir | expanduser }}/{{ jetbrains_ide }}/{{ jetbrains_ide_info[jetbrains_ide].icon }}
Exec="{{ ide_unpack_dir | expanduser }}/{{ jetbrains_ide }}/{{ jetbrains_ide_info[jetbrains_ide].executable }}" %f
Comment={{ jetbrains_ide_info[jetbrains_ide].comment }}
Categories=Development;IDE
Terminal=false
StartupWMClass={{ jetbrains_ide_info[jetbrains_ide].startup_wm_class }}
Keywords=programming;programmer;development;developer;code;
StartupNotify=true
