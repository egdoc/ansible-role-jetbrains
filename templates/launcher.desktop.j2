[Desktop Entry]
Version=1.0
Type=Application
Name={{ jetbrains_ide_info[ide_name].name }}
Icon={{ jetbrains_ide_data_dir | expanduser }}/{{ jetbrains_ide_info[ide_name].icon }}
Exec="{{ jetbrains_ide_data_dir | expanduser }}/{{ jetbrains_ide_info[ide_name].executable }}" %f
Comment={{ jetbrains_ide_info[ide_name].comment }}
Categories=Development;IDE
Terminal=false
StartupWMClass={{ jetbrains_ide_info[ide_name].startup_wm_class }}
Keywords=programming;programmer;development;developer;code;
StartupNotify=true
